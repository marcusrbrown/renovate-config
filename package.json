{
  "name": "@marcusrbrown/renovate-config",
  "version": "0.0.0-development",
  "private": true,
  "description": "Shareable Renovate configuration presets for my personal GitHub repositories.",
  "keywords": [
    "renovate-config"
  ],
  "homepage": "https://github.com/marcusrbrown/renovate-config#readme",
  "bugs": {
    "url": "https://github.com/marcusrbrown/renovate-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcusrbrown/renovate-config.git"
  },
  "license": "MIT",
  "author": "Marcus R. Brown <contact@marcusrbrown.com> (https://marcusrbrown.com/)",
  "type": "module",
  "main": "default.json",
  "scripts": {
    "bootstrap": "pnpm install --no-strict-peer-dependencies --prefer-offline",
    "lint": "eslint",
    "fix": "eslint --fix",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,json,jsx,md,toml,ts,tsx,yml,yaml}": [
      "pnpm run fix"
    ]
  },
  "prettier": "@bfra.me/prettier-config/120-proof",
  "devDependencies": {
    "@bfra.me/eslint-config": "0.51.1",
    "@bfra.me/prettier-config": "0.16.9",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "lint-staged": "17.0.4",
    "markdownlint": "0.40.0",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "semantic-release-export-data": "1.2.0",
    "simple-git-hooks": "2.13.1"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "flatted": ">=3.4.2",
      "handlebars": ">=4.7.9",
      "lodash-es": ">=4.18.0",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4"
    }
  }
}
